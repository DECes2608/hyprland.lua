{
  "layer": "top",
  "position": "bottom",
  "height": 26,
  "spacing": 2,
  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["custom/music"],
  "modules-right": ["tray", "custom/warp", "memory", "pulseaudio", "network", "custom/bluetooth", "clock"],

  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "active-only": false,
    "show-special": true,
    "on-click": "activate",
    "format": "{icon}",
    "format-icons": {
      "1": "",
      "2": "󰈹",
      "3": "󰉋",
      "4": "󰓓",
      "5": "",
      "6": "",
      "special": "󰣇",
    },
  },

  "custom/warp": {
    "format": "{}",
    "return-type": "json",
    "interval": 2,
    "exec": "~/.config/waybar/scripts/warp-toggle.sh",
    "on-click": "~/.config/waybar/scripts/warp-toggle.sh toggle",
    "tooltip": true
},

  "custom/music": {
    "format": "{}",
    "return-type": "json",
    "max-length": 40,
    "exec": "~/.config/waybar/scripts/ncspot_poll.sh",
    "interval": 2,
    "on-click": "playerctl -p ncspot play-pause",
    "on-click-right": "~/.config/waybar/scripts/toggle_music_workspace.sh"
  },

  "custom/bluetooth": {
    "exec": "bluetoothctl show | grep -q 'Powered: yes' && echo '󰂯' || echo '󰂲'",
    "on-click": "blueman-manager",
    "on-click-right": "bluetoothctl power $(bluetoothctl show | grep -q 'Powered: yes' && echo 'off' || echo 'on')",
    "format": "{}",
    "interval": 2,
  },

  "memory": {
    "interval": 2,
    "format": "󰍛 {used:0.1f}G",
    "tooltip-format": "Kullanılan: {used:0.1f}G / {total:0.1f}G",
  },

  "clock": {
    "format": "{:%H:%M  %a %d}",
    "locale": "tr_TR.utf8",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
},

  "network": {
    "on-click": "nm-connection-editor",
    "on-click-right": "kitty -e nmtui",
    "format-wifi": "󰤨",
    "format-ethernet": "󰈀",
    "format-linked": "󰈀",
    "format-disconnected": "󰤭",
    "tooltip-format": "{essid} — {signalStrength}%",
  },

  "pulseaudio": {
    "format": "󰕾 {volume}%",
    "format-muted": "󰝟",
    "on-click": "pavucontrol",
  },

  "tray": {
    "icon-size": 14,
    "spacing": 6,
  },
}
